import 'dart:async';
import 'dart:math';
import 'package:flutter/material.dart';
import 'package:audioplayers/audioplayers.dart';

class ButterflyAICharacter extends StatefulWidget {
  const ButterflyAICharacter({super.key});

  @override
  State<ButterflyAICharacter> createState() => _ButterflyAICharacterState();
}

class _ButterflyAICharacterState extends State<ButterflyAICharacter>
    with TickerProviderStateMixin {
  final AudioPlayer _audioPlayer = AudioPlayer();
  final Random _rand = Random();

  // Flower positions
  final List<Offset> flowerPositions = [
    const Offset(50, 150),
    const Offset(280, 400),
    const Offset(120, 620),
  ];

  final List<Color> flowerColors = [
    Colors.pinkAccent,
    Colors.yellowAccent,
    Colors.purpleAccent,
  ];

  int currentFlower = 0;
  int? landedFlower; // which flower butterfly is sitting on
  bool _isLanded = false;
  bool _isTakingOff = false;

  // --- Animation Controllers ---

  // Float up/down while flying
  late AnimationController _floatCtrl;
  late Animation<double> _floatY;

  // Wing flap (scaleX) while flying
  late AnimationController _flapCtrl;
  late Animation<double> _flapScale;

  // Glow pulse
  late AnimationController _glowCtrl;
  late Animation<double> _glowOpacity;

  // Spin on takeoff
  late AnimationController _spinCtrl;
  late Animation<double> _spinAngle;

  // Gentle sway while sitting
  late AnimationController _swayCtrl;
  late Animation<double> _swayAngle;

  Timer? _flightTimer;
  Timer? _landTimer;

  @override
  void initState() {
    super.initState();

    // Float
    _floatCtrl = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 1800),
    )..repeat(reverse: true);
    _floatY = Tween<double>(begin: -10, end: 10).animate(
      CurvedAnimation(parent: _floatCtrl, curve: Curves.easeInOut),
    );

    // Flap
    _flapCtrl = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 320),
    )..repeat(reverse: true);
    _flapScale = Tween<double>(begin: 0.65, end: 1.0).animate(
      CurvedAnimation(parent: _flapCtrl, curve: Curves.easeInOut),
    );

    // Glow
    _glowCtrl = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 1500),
    )..repeat(reverse: true);
    _glowOpacity = Tween<double>(begin: 0.3, end: 0.85).animate(_glowCtrl);

    // Spin (one-shot on takeoff)
    _spinCtrl = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 650),
    );
    _spinAngle = Tween<double>(begin: 0, end: 2 * pi).animate(
      CurvedAnimation(parent: _spinCtrl, curve: Curves.easeInOut),
    );

    // Sway (while landed)
    _swayCtrl = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 1600),
    )..repeat(reverse: true);
    _swayAngle = Tween<double>(begin: -0.07, end: 0.07).animate(
      CurvedAnimation(parent: _swayCtrl, curve: Curves.easeInOut),
    );

    _scheduleNextMove();
  }

  void _scheduleNextMove() {
    final delay = 3000 + _rand.nextInt(3000); // 3â€“6 seconds
    _flightTimer = Timer(Duration(milliseconds: delay), () {
      if (!mounted) return;
      if (_isLanded) {
        _takeOff();
      } else {
        _flyToFlower();
      }
    });
  }

  void _flyToFlower() async {
    if (!mounted) return;

    // Pick next flower
    final nextFlower = (currentFlower + 1) % flowerPositions.length;

    setState(() {
      currentFlower = nextFlower;
      _isLanded = false;
      _isTakingOff = false;
    });

    _playFlapSound();

    // Resume fly animations
    _floatCtrl.repeat(reverse: true);
    _flapCtrl.repeat(reverse: true);

    // Wait for AnimatedPositioned to arrive
    await Future.delayed(const Duration(milliseconds: 2600));
    if (!mounted) return;

    _land(nextFlower);
  }

  void _land(int flowerIndex) {
    if (!mounted) return;

    setState(() {
      _isLanded = true;
      landedFlower = flowerIndex;
    });

    // Stop fly animations
    _floatCtrl.stop();
    _flapCtrl.stop();

    // Sit for 3â€“6 seconds
    final sitTime = 3000 + _rand.nextInt(3000);
    _landTimer = Timer(Duration(milliseconds: sitTime), () {
      if (mounted) _takeOff();
    });
  }

  void _takeOff() async {
    if (!mounted) return;

    setState(() {
      _isTakingOff = true;
      _isLanded = false;
      landedFlower = null;
    });

    // Spin on takeoff
    await _spinCtrl.forward(from: 0);

    if (!mounted) return;

    setState(() {
      _isTakingOff = false;
    });

    // Resume flying then go to next flower
    _floatCtrl.repeat(reverse: true);
    _flapCtrl.repeat(reverse: true);
    _playFlapSound();

    _scheduleNextMove();
  }

  void _playFlapSound() async {
    try {
      await _audioPlayer.play(AssetSource('sounds/wing.wav'));
    } catch (e) {
      debugPrint('Sound error: $e');
    }
  }

  Color get _glowColor {
    if (_isLanded) return flowerColors[currentFlower];
    return Colors.cyanAccent;
  }

  Offset get _butterflyOffset {
    final flower = flowerPositions[currentFlower];
    // Hover slightly above flower center
    return Offset(flower.dx + 10, flower.dy - 50);
  }

  @override
  void dispose() {
    _flightTimer?.cancel();
    _landTimer?.cancel();
    _floatCtrl.dispose();
    _flapCtrl.dispose();
    _glowCtrl.dispose();
    _spinCtrl.dispose();
    _swayCtrl.dispose();
    _audioPlayer.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Stack(
      children: [
        // Flowers
        ...List.generate(flowerPositions.length, (i) {
          final isActive = landedFlower == i;
          return _buildFlower(i, isActive);
        }),

        // Butterfly
        AnimatedPositioned(
          duration: const Duration(milliseconds: 2500),
          curve: Curves.easeInOutCubic,
          left: _butterflyOffset.dx,
          top: _butterflyOffset.dy,
          child: AnimatedBuilder(
            animation: Listenable.merge([
              _floatCtrl,
              _flapCtrl,
              _glowCtrl,
              _spinCtrl,
              _swayCtrl,
            ]),
            builder: (context, _) {
              double rotation = 0;
              if (_isLanded) {
                rotation = _swayAngle.value;
              } else if (_isTakingOff) {
                rotation = _spinAngle.value;
              }

              final floatOffset = _isLanded ? 0.0 : _floatY.value;
              final wingScale = _isLanded ? 1.0 : _flapScale.value;

              return Transform.translate(
                offset: Offset(0, floatOffset),
                child: Transform.rotate(
                  angle: rotation,
                  child: Container(
                    decoration: BoxDecoration(
                      shape: BoxShape.circle,
                      boxShadow: [
                        BoxShadow(
                          color: _glowColor.withOpacity(_glowOpacity.value),
                          blurRadius: _isLanded ? 55 : 30,
                          spreadRadius: _isLanded ? 12 : 4,
                        ),
                      ],
                    ),
                    child: Transform(
                      alignment: Alignment.center,
                      transform: Matrix4.identity()..scale(wingScale, 1.0),
                      child: Image.asset(
                        'assets/orange_cyan_butterfly.png',
                        width: 85,
                        height: 85,
                      ),
                    ),
                  ),
                ),
              );
            },
          ),
        ),
      ],
    );
  }

  Widget _buildFlower(int index, bool isActive) {
    final pos = flowerPositions[index];
    final color = flowerColors[index];

    return Positioned(
      left: pos.dx,
      top: pos.dy,
      child: AnimatedContainer(
        duration: const Duration(milliseconds: 500),
        decoration: BoxDecoration(
          shape: BoxShape.circle,
          boxShadow: [
            BoxShadow(
              color: color.withOpacity(isActive ? 0.7 : 0.3),
              blurRadius: isActive ? 70 : 40,
              spreadRadius: isActive ? 15 : 8,
            ),
          ],
        ),
        child: Image.asset(
          'assets/emowall_flower.png',
          width: 110,
          height: 110,
        ),
      ),
    );
  }
}
